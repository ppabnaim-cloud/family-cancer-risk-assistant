# Copy to .env.local for local development (vercel dev).
# In production these are set in Vercel → Settings → Environment Variables.
# NEVER commit real values — .env.local is gitignored.

# CPG Q&A chat panel
ANTHROPIC_API_KEY=sk-ant-...

# Feedback form → EmailJS
EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_TEMPLATE_ID=template_xxxxxxx
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_PRIVATE_KEY=your_emailjs_private_key

# Optional. Only used if your EmailJS template's "To Email" field is {{to_email}}.
FEEDBACK_TO_EMAIL=nurulamieraasli@gmail.com
